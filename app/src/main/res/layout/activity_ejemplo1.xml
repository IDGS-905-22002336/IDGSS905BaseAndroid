<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgeound"
    android:orientation="vertical"
    tools:context=".Ejemplo1.Ejemplo1">

    <LinearLayout

        android:orientation="vertical"
        android:gravity="center"
        android:layout_margin="15dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/user" />

        <EditText
            android:id="@+id/edtNumero1"
            android:layout_width="323dp"
            android:layout_height="48dp"
            android:ems="10"
            android:hint="Numero1"
            android:inputType="number"
            android:textColor="@color/white" />

        <EditText
            android:id="@+id/edtNumero2"
            android:layout_width="323dp"
            android:layout_height="48dp"
            android:ems="10"
            android:hint="Numero2"
            android:inputType="number"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/btnSumar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sumar"
            android:layout_marginTop="15dp"/>

        <TextView
            android:id="@+id/txtResultado"
            android:layout_width="177dp"
            android:layout_height="61dp"
            android:text="Resultado: 0"
            android:textSize="25dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/btnIrDistancia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="Ir a Distancia" />


    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>